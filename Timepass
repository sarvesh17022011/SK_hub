-- SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- STATE
local infiniteJumpEnabled = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "InfiniteJumpToggleGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 100)
frame.Position = UDim2.new(0.5, -110, 0.4, 0)
frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "Infinite Jump"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
title.Parent = frame

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 160, 0, 40)
button.Position = UDim2.new(0.5, -80, 0, 45)
button.Text = "OFF"
button.TextScaled = true
button.BackgroundColor3 = Color3.fromRGB(170, 60, 60)
button.TextColor3 = Color3.new(1,1,1)
button.Parent = frame

-- BUTTON LOGIC
button.MouseButton1Click:Connect(function()
	infiniteJumpEnabled = not infiniteJumpEnabled

	if infiniteJumpEnabled then
		button.Text = "ON"
		button.BackgroundColor3 = Color3.fromRGB(60, 170, 60)
	else
		button.Text = "OFF"
		button.BackgroundColor3 = Color3.fromRGB(170, 60, 60)
	end
end)

-- INFINITE JUMP
UserInputService.JumpRequest:Connect(function()
	if infiniteJumpEnabled then
		local character = player.Character
		if character then
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end
	end
end)

print("Infinite Jump toggle loaded")
